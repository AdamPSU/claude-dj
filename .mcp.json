{
  "mcpServers": {
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "redis": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url",
        "redis://default:${REDIS_PASSWORD}@sugar-daylit-corn-40583.db.redis.io:18497/0"
      ],
      "env": {}
    },
    "deepgram": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "deepctl",
        "dg",
        "mcp",
        "--non-interactive"
      ],
      "env": {}
    },
    "WaveSpeed": {
      "type": "stdio",
      "command": "wavespeed-mcp",
      "env": {
        "WAVESPEED_API_KEY": "${WAVESPEED_API_KEY}"
      }
    }
  }
}

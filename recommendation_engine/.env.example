# Copy to .env and fill in. .env is git-ignored.

# --- Spotify (Phase 1) ---
# Public playlist + client-credentials flow. Create an app at developer.spotify.com.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_PLAYLIST_ID=

# --- Redis (Phase 4 & 5) ---
# A remote Redis Cloud instance already exists for this project (see repo root redis.py).
REDIS_HOST=sugar-daylit-corn-40583.db.redis.io
REDIS_PORT=18497
REDIS_USERNAME=default
REDIS_PASSWORD=

# --- CLAP (Phase 3) ---
# Music checkpoint filename; download from the LAION-CLAP model release.
CLAP_CHECKPOINT=music_audioset_epoch_15_esc_90.14.pt
